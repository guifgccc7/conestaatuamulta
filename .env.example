# ════════════════════════════════════════════════════════════════════════════════
# conestaatuamulta.pt — Environment Variables
# Copy this file to .env.local (local dev) or paste into Railway / hosting panel
# ════════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# Production (Railway gives you this automatically when you add the Postgres plugin)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── NextAuth.js ───────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_32_BYTE_BASE64_STRING"
# Must match your live domain (no trailing slash)
NEXTAUTH_URL="https://conestaatuamulta.pt"

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test:  sk_test_ / pk_test_   Live: sk_live_ / pk_live_
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY="sk_live_YOUR_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_YOUR_KEY"

# Price IDs (Stripe Dashboard → Product catalog)
STRIPE_PRICE_SINGLE_DOC="price_1TNAhBK0pUBovyXTcjMshTUE"   # €9.90 one-time
STRIPE_PRICE_SUBSCRIPTION="price_1TM73nK0pUBovyXTnv5Cslt6"  # €4.90/month

# ── Anthropic / AI ────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-YOUR_KEY"

# ── Email / SMTP (optional — leave blank to disable) ─────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Contesta a Tua Multa <noreply@conestaatuamulta.pt>"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://conestaatuamulta.pt"
NEXT_PUBLIC_APP_NAME="Contesta a Tua Multa"
